# Cloudflare R2 (compatible con S3)
AWS_ACCESS_KEY_ID=tu_access_key
AWS_SECRET_ACCESS_KEY=tu_secret_key
AWS_REGION=auto
AWS_S3_ENDPOINT_URL=https://tu_account_id.r2.cloudflarestorage.com
AWS_S3_BUCKET=signa
AWS_S3_PRESIGNED_URL_EXPIRATION=3600

# LiveKit (voice intake)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Gemini (agent worker + POST /escaneo con engine=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_MAX_OUTPUT_TOKENS=16384

# Logging (stdout via uvicorn console)
LOG_LEVEL=INFO

# CORS — use * for all origins, or comma-separated list
CORS_ORIGINS=*
