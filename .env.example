# Cloudflare R2 (compatible con S3)
AWS_ACCESS_KEY_ID=tu_access_key
AWS_SECRET_ACCESS_KEY=tu_secret_key
AWS_REGION=auto
AWS_S3_ENDPOINT_URL=https://tu_account_id.r2.cloudflarestorage.com
AWS_S3_BUCKET=signa
AWS_S3_PRESIGNED_URL_EXPIRATION=3600

# LiveKit (voice intake)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Gemini (agent worker only)
GEMINI_API_KEY=

# CORS — signa-api frontend dev server
CORS_ORIGINS=http://localhost:3000
